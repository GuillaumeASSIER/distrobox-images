{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "next-devtools": {
      "type": "local",
      "command": ["bunx", "next-devtools-mcp@latest"],
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "opentofu": {
      "type": "remote",
      "url": "https://mcp.opentofu.org/sse"
    },
    "terraform": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "hashicorp/terraform-mcp-server"
      ],
      "enabled": true
    }
  }
}
